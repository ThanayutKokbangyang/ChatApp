@inherits LayoutComponentBase
@implements IDisposable
@inject AuthApiService AuthService
@inject ChatApiService ChatService
@inject NavigationManager Navigation

<div class="layout">
    <header class="topbar">
        <div class="brand" @onclick="@(() => Navigation.NavigateTo("/"))">
            💬 ChatApp
        </div>

        <AuthorizeView>
            <Authorized>
                <nav class="nav-menu">
                    <NavLink href="/" Match="NavLinkMatch.All" class="nav-link">
                        ห้องแชท
                    </NavLink>
                </nav>

                <div class="user-menu-wrapper">
                    <button class="user-menu-button" @onclick="ToggleUserMenu">
                        @if (!string.IsNullOrEmpty(_avatarUrl))
                        {
                            <img src="@GetAvatarUrl(_avatarUrl)" class="topbar-avatar" />
                        }
                        else
                        {
                            <span class="topbar-avatar-placeholder">
                                @GetInitial(context.User.Identity?.Name)
                            </span>
                        }

                        <span>สวัสดี, @context.User.Identity?.Name</span>
                        <span class="dropdown-arrow">▾</span>
                    </button>

                    @if (_showUserMenu)
                    {
                        <div class="user-dropdown">
                            <div class="dropdown-profile">
                                @if (!string.IsNullOrEmpty(_avatarUrl))
                                {
                                    <img src="@GetAvatarUrl(_avatarUrl)" class="dropdown-avatar" />
                                }
                                else
                                {
                                    <div class="dropdown-avatar-placeholder">
                                        @GetInitial(context.User.Identity?.Name)
                                    </div>
                                }

                                <div>
                                    <strong>@context.User.Identity?.Name</strong>
                                    <small>บัญชีของฉัน</small>
                                </div>
                            </div>

                            <button class="dropdown-item" @onclick="GoToProfile">
                                แก้ไขโปรไฟล์
                            </button>

                            <button class="dropdown-item logout" @onclick="LogoutAsync">
                                ออกจากระบบ
                            </button>
                        </div>
                    }
                </div>
            </Authorized>
        </AuthorizeView>
    </header>

    <main class="content" @onclick="CloseUserMenu">
        @Body
    </main>
</div>

@code {
    private bool _showUserMenu;
    private string? _avatarUrl;

    protected override async Task OnInitializedAsync()
    {
        ChatService.AvatarUpdated += OnAvatarUpdated;

        try
        {
            var profile = await ChatService.GetMyProfileAsync();
            _avatarUrl = profile?.AvatarUrl is null
                ? null
                : AddCacheBuster(profile.AvatarUrl);
        }
        catch
        {
            // ยังไม่ login หรือ profile ยังไม่มี ไม่ต้องทำอะไร
        }
    }

    private void OnAvatarUpdated(string avatarUrl)
    {
        _avatarUrl = AddCacheBuster(avatarUrl);
        InvokeAsync(StateHasChanged);
    }

    private void ToggleUserMenu()
    {
        _showUserMenu = !_showUserMenu;
    }

    private void CloseUserMenu()
    {
        _showUserMenu = false;
    }

    private void GoToProfile()
    {
        _showUserMenu = false;
        Navigation.NavigateTo("/profile");
    }

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }

    private static string AddCacheBuster(string url)
    {
        var separator = url.Contains('?') ? "&" : "?";
        return $"{url}{separator}v={DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}";
    }

    private static string GetAvatarUrl(string? avatarUrl)
    {
        if (string.IsNullOrWhiteSpace(avatarUrl))
            return string.Empty;

        if (avatarUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            return avatarUrl;

        return avatarUrl.StartsWith("/")
            ? $"/chat{avatarUrl}"
            : $"/chat/{avatarUrl}";
    }

    private static string GetInitial(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "?";

        return name[0].ToString().ToUpper();
    }

    public void Dispose()
    {
        ChatService.AvatarUpdated -= OnAvatarUpdated;
    }
}