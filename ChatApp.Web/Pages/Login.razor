@page "/login"
@layout MainLayout
@inject AuthApiService AuthService
@inject NavigationManager Navigation

<PageTitle>เข้าสู่ระบบ</PageTitle>

<div class="auth-card">
    <h2>เข้าสู่ระบบ</h2>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-error">@_error</div>
    }

    <EditForm Model="@_loginModel" OnValidSubmit="HandleLogin">
        <DataAnnotationsValidator />

        <div class="form-group">
            <label>Email</label>
            <InputText @bind-Value="_loginModel.Email" class="form-control" />
        </div>

        <div class="form-group">
            <label>รหัสผ่าน</label>
            <InputText type="password" @bind-Value="_loginModel.Password" class="form-control" />
        </div>

        <button type="submit" class="btn-primary" disabled="@_loading">
            @(_loading ? "กำลังเข้าสู่ระบบ..." : "เข้าสู่ระบบ")
        </button>
    </EditForm>

    <p class="link-row">
        ยังไม่มีบัญชี? <a href="/register">สมัครสมาชิก</a>
    </p>
</div>

@code {
    private LoginModel _loginModel = new();
    private string _error = string.Empty;
    private bool _loading;

    private async Task HandleLogin()
    {
        _loading = true;
        _error = string.Empty;

        var success = await AuthService.LoginAsync(_loginModel.Email, _loginModel.Password);
        _loading = false;

        if (success)
        {
            Navigation.NavigateTo("/");
        }
        else
        {
            _error = "Email หรือรหัสผ่านไม่ถูกต้อง";
        }
    }

    public class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
